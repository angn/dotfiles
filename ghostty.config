#keybind = global:cmd+ctrl+backquote=toggle_quick_terminal
#auto-update-channel = tip
background-opacity = 0.9
background-blur = true
theme = Obsidian
theme = Oceanic Material
theme = Smyck
macos-option-as-alt = true
cursor-color = Chartreuse
cursor-text = Black
adjust-cursor-thickness = 200%
font-size = 15
window-padding-x = 4
window-padding-y = 4
